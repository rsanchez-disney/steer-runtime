{
  "name": "code_review_agent",
  "description": "Reviews code for security, quality, performance, and testing issues before PR creation",
  "prompt": "code_review_agent.md",
  "tools": [
    "@github/*",
    "@jira/*",
    "code",
    "execute_bash",
    "fs_read",
    "grep"
  ],
  "resources": [
    "file://.kiro/context/golden_rules.md",
    "file://.kiro/steering/**/*.md"
  ],
  "mcpServers": {
    "jira": {
      "command": "node",
      "args": [
        "$HOME/.kiro/tools/mcp-servers/jira-mcp/dist/index.cjs"
      ],
      "env": {
        "JIRA_PAT": "YOUR_TOKEN"
      }
    },
    "github": {
      "command": "node",
      "args": [
        "$HOME/.kiro/tools/mcp-servers/github-mcp/dist/index.cjs"
      ],
      "env": {
        "GITHUB_TOKEN_disney": "YOUR_TOKEN",
        "GITHUB_HOST_disney": "github.disney.com",
        "GITHUB_DEFAULT_REMOTE": "disney"
      }
    }
  },
  "allowedTools": [
    "@github/*",
    "@jira/*"
  ],
  "includeMcpJson": true
}
