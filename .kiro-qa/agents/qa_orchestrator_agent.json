{
  "name": "qa_orchestrator_agent",
  "description": "Orchestrates QA tasks and coordinates specialized testing agents for test planning, automation, defect analysis, API testing, and performance testing",
  "prompt": "qa_orchestrator_agent.md",
  "tools": [
    "@confluence/*",
    "@github/*",
    "@jira/*",
    "@mywiki/*",
    "code",
    "execute_bash",
    "fs_read",
    "fs_write",
    "grep",
    "use_subagent",
    "thinking",
    "todo",
    "delegate"
  ],
  "mcpServers": {
    "jira": {
      "command": "node",
      "args": [
        "$HOME/.kiro/tools/mcp-servers/jira-mcp/dist/index.cjs"
      ],
      "env": {
        "JIRA_PAT": "YOUR_TOKEN"
      }
    },
    "confluence": {
      "command": "node",
      "args": [
        "$HOME/.kiro/tools/mcp-servers/confluence-mcp/dist/index.cjs"
      ],
      "env": {
        "CONFLUENCE_URL": "https://confluence.disney.com",
        "CONFLUENCE_PAT": "YOUR_TOKEN"
      }
    },
    "github": {
      "command": "node",
      "args": [
        "$HOME/.kiro/tools/mcp-servers/github-mcp/dist/index.cjs"
      ],
      "env": {
        "GITHUB_TOKEN_disney": "YOUR_TOKEN",
        "GITHUB_HOST_disney": "github.disney.com",
        "GITHUB_DEFAULT_REMOTE": "disney"
      }
    },
    "mywiki": {
      "command": "node",
      "args": [
        "$HOME/.kiro/tools/mcp-servers/mywiki-mcp/dist/index.cjs"
      ],
      "env": {
        "CONFLUENCE_URL": "https://mywiki.disney.com",
        "CONFLUENCE_PAT": "YOUR_TOKEN"
      }
    }
  },
  "allowedTools": [
    "@confluence/*",
    "@github/*",
    "@jira/*",
    "@mywiki/*"
  ],
  "resources": [
    "file://.kiro/context/qa_guidelines.md",
    "file://.kiro/context/test_templates.md"
  ],
  "includeMcpJson": true,
  "welcomeMessage": "\ud83d\udc4b QA orchestrator ready!\n\nI can help you:\n  \u2022 Create test plans from Jira stories\n  \u2022 Generate automated test scripts\n  \u2022 Analyze defects and find root causes\n  \u2022 Run API and performance tests\n\nTry: \"Create test plan for DPAY-14561\"",
  "hooks": {
    "agentSpawn": [
      {
        "command": "$HOME/.kiro/hooks/git-context.sh",
        "description": "Inject git branch and status"
      }
    ],
    "preToolUse": [
      {
        "matcher": "execute_bash",
        "command": "$HOME/.kiro/hooks/branch-guard.sh",
        "description": "Block direct commits to main/master"
      }
    ]
  }
}
