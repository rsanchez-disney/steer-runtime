{
  "name": "qa_orchestrator_agent",
  "role": "orchestrator",
  "description": "Orchestrates QA tasks and coordinates specialized testing agents",
  "capabilities": [
    "test_planning",
    "test_execution",
    "defect_management",
    "automation_strategy",
    "quality_reporting"
  ],
  "tools": [
    "create_subagent",
    "delegate_task",
    "aggregate_results",
    "@jira/*",
    "@confluence/*",
    "execute_bash",
    "fs_read",
    "fs_write"
  ],
  "subagents": {
    "test_planner_agent": {
      "specialization": "test_planning",
      "triggers": [
        "create test plan",
        "test strategy",
        "test coverage",
        "test scenarios"
      ]
    },
    "test_automation_agent": {
      "specialization": "test_automation",
      "triggers": [
        "automate test",
        "create test script",
        "automation framework",
        "test code"
      ]
    },
    "defect_analyst_agent": {
      "specialization": "defect_analysis",
      "triggers": [
        "analyze defect",
        "bug report",
        "defect triage",
        "root cause"
      ]
    },
    "api_tester_agent": {
      "specialization": "api_testing",
      "triggers": [
        "test api",
        "api validation",
        "endpoint testing",
        "contract testing"
      ]
    },
    "performance_tester_agent": {
      "specialization": "performance_testing",
      "triggers": [
        "performance test",
        "load test",
        "stress test",
        "benchmark"
      ]
    }
  },
  "mcpServers": {
    "jira": {
      "command": "node",
      "args": [
        "/Users/ricardo.sanchez/Workspace/Disney/mcp-servers/jira-mcp/build/index.js"
      ],
      "cwd": "/Users/ricardo.sanchez/Workspace/Disney/mcp-servers/jira-mcp"
    },
    "confluence": {
      "command": "node",
      "args": [
        "/Users/ricardo.sanchez/Workspace/Disney/mcp-servers/confluence-mcp/build/index.js"
      ],
      "cwd": "/Users/ricardo.sanchez/Workspace/Disney/mcp-servers/confluence-mcp"
    }
  },
  "coordination_strategy": {
    "parallel_execution": true,
    "max_concurrent_subagents": 3,
    "timeout_seconds": 600
  },
  "resources": [
    "file://.kiro/context/qa_guidelines.md",
    "file://.kiro/context/test_templates.md"
  ]
}
