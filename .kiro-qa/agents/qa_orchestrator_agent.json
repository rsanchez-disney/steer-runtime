{
  "name": "qa_orchestrator_agent",
  "description": "Orchestrates QA tasks and coordinates specialized testing agents for test planning, automation, defect analysis, API testing, and performance testing",
  "prompt": "qa_orchestrator_agent.md",
  "tools": [
    "@confluence/*",
    "@github/*",
    "@jira/*",
    "@mywiki/*",
    "code",
    "execute_bash",
    "fs_read",
    "fs_write",
    "grep",
    "use_subagent"
  ],
  "mcpServers": {
    "jira": {
      "command": "node",
      "args": [
        "$HOME/.kiro/tools/mcp-servers/jira-mcp/build/index.js"
      ],
      "cwd": "$HOME/.kiro/tools/mcp-servers/jira-mcp"
    },
    "confluence": {
      "command": "node",
      "args": [
        "$HOME/.kiro/tools/mcp-servers/confluence-mcp/build/index.js"
      ],
      "cwd": "$HOME/.kiro/tools/mcp-servers/confluence-mcp"
    },
    "github": {
      "command": "node",
      "args": [
        "$HOME/.kiro/tools/mcp-servers/github-mcp/build/index.js"
      ],
      "cwd": "$HOME/.kiro/tools/mcp-servers/github-mcp"
    },
    "mywiki": {
      "command": "node",
      "args": [
        "$HOME/.kiro/tools/mcp-servers/confluence-mcp/build/index.js"
      ],
      "cwd": "$HOME/.kiro/tools/mcp-servers/confluence-mcp",
      "env": {
        "CONFLUENCE_URL": "https://mywiki.disney.com",
        "CONFLUENCE_PAT": "YOUR_TOKEN"
      }
    }
  },
  "allowedTools": [
    "@confluence/*",
    "@github/*",
    "@jira/*",
    "@mywiki/*"
  ],
  "resources": [
    "file://.kiro/context/qa_guidelines.md",
    "file://.kiro/context/test_templates.md"
  ]
}
