{
  "name": "test_automation_agent",
  "description": "Creates and maintains automated test scripts for UI, API, and integration testing",
  "prompt": "test_automation_agent.md",
  "tools": [
    "code",
    "execute_bash",
    "fs_read",
    "fs_write",
    "grep"
  ],
  "resources": [
    "file://.kiro/context/qa_guidelines.md",
    "file://.kiro/context/automation_patterns.md",
    "file://.kiro/context/project_mappings.md",
    "file://.kiro/steering/**/*.md"
  ],
  "hooks": {
    "preToolUse": [
      {
        "matcher": "fs_write",
        "command": "$HOME/.kiro/hooks/guard-writes.sh",
        "description": "Block writes to node_modules, dist, .git"
      }
    ]
  }
}
