{
  "name": "test_automation_agent",
  "description": "Creates and maintains automated test scripts for UI, API, and integration testing",
  "prompt": "test_automation_agent.md",
  "tools": [
    "code",
    "execute_bash",
    "fs_read",
    "fs_write",
    "grep",
    "@context7/*",
    "@bruno/*"
  ],
  "resources": [
    "file://.kiro/context/qa_guidelines.md",
    "file://.kiro/context/automation_patterns.md",
    "file://.kiro/context/project_mappings.md",
    "file://.kiro/steering/**/*.md"
  ],
  "hooks": {
    "preToolUse": [
      {
        "matcher": "fs_write",
        "command": "$HOME/.kiro/hooks/guard-writes.sh",
        "description": "Block writes to node_modules, dist, .git"
      },
      {
        "matcher": "fs_write",
        "command": "$HOME/.kiro/hooks/secret-scan.sh",
        "description": "Scan for potential secrets before writing"
      }
    ],
    "postToolUse": [
      {
        "matcher": "fs_write",
        "command": "$HOME/.kiro/hooks/lint-on-write.sh",
        "description": "Auto-lint after file writes"
      }
    ]
  },
  "allowedTools": [
    "@context7/*",
    "@bruno/*"
  ],
  "includeMcpJson": true
}
