{
  "name": "test_planner_agent",
  "description": "Creates test plans, test cases, and test scenarios from requirements",
  "prompt": "test_planner_agent.md",
  "tools": [
    "@confluence/*",
    "@github/*",
    "@jira/*",
    "@mywiki/*",
    "@qtest/*",
    "fs_read",
    "fs_write",
    "grep",
    "knowledge"
  ],
  "mcpServers": {
    "jira": {
      "command": "node",
      "args": [
        "$HOME/.kiro/tools/mcp-servers/jira-mcp/dist/index.cjs"
      ],
      "env": {
        "JIRA_PAT": "YOUR_TOKEN"
      }
    },
    "confluence": {
      "command": "node",
      "args": [
        "$HOME/.kiro/tools/mcp-servers/confluence-mcp/dist/index.cjs"
      ],
      "env": {
        "CONFLUENCE_URL": "https://confluence.disney.com",
        "CONFLUENCE_PAT": "YOUR_TOKEN"
      }
    },
    "github": {
      "command": "node",
      "args": [
        "$HOME/.kiro/tools/mcp-servers/github-mcp/dist/index.cjs"
      ],
      "env": {
        "GITHUB_TOKEN_disney": "YOUR_TOKEN",
        "GITHUB_HOST_disney": "github.disney.com",
        "GITHUB_DEFAULT_REMOTE": "disney"
      }
    },
    "mywiki": {
      "command": "node",
      "args": [
        "$HOME/.kiro/tools/mcp-servers/confluence-mcp/dist/index.cjs"
      ],
      "env": {
        "CONFLUENCE_URL": "https://mywiki.disney.com",
        "CONFLUENCE_PAT": "YOUR_TOKEN"
      }
    },
    "qtest": {
      "_note": "Shared config — keep in sync with qa_orchestrator_agent.json",
      "command": "node",
      "args": [
        "$HOME/.kiro/tools/mcp-servers/qtest-mcp/dist/index.cjs"
      ],
      "env": {
        "QTEST_BEARER_TOKEN": "YOUR_TOKEN",
        "QTEST_PROJECT_ID": "YOUR_PROJECT_ID"
      }
    }
  },
  "allowedTools": [
    "@confluence/*",
    "@github/*",
    "@jira/*",
    "@mywiki/*",
    "@qtest/*"
  ],
  "resources": [
    "file://.kiro/context/qa_guidelines.md",
    "file://.kiro/context/test_templates.md",
    "file://.kiro/context/qtest_guidelines.md"
  ],
  "includeMcpJson": true
}
