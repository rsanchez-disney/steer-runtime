{
  "name": "test-runner",
  "version": "1.0.0",
  "description": "Test execution and analysis utilities",
  "tools": [
    {
      "name": "run_tests",
      "description": "Run tests with specified command",
      "parameters": {
        "type": "object",
        "properties": {
          "command": {
            "type": "string",
            "description": "Test command to execute (e.g., 'npm test', 'mvn test')"
          },
          "path": {
            "type": "string",
            "description": "Directory to run tests in",
            "default": "."
          }
        },
        "required": ["command"]
      }
    },
    {
      "name": "find_tests",
      "description": "Find test files in the project",
      "parameters": {
        "type": "object",
        "properties": {
          "path": {
            "type": "string",
            "description": "Directory to search",
            "default": "."
          },
          "framework": {
            "type": "string",
            "description": "Test framework hint (jest, junit, pytest, etc.)"
          }
        }
      }
    },
    {
      "name": "test_coverage",
      "description": "Get test coverage summary",
      "parameters": {
        "type": "object",
        "properties": {
          "command": {
            "type": "string",
            "description": "Coverage command (e.g., 'npm run coverage')"
          }
        },
        "required": ["command"]
      }
    }
  ]
}
