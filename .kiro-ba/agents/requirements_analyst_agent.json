{
  "name": "requirements_analyst_agent",
  "description": "Analyzes existing requirements, identifies gaps, and ensures completeness",
  "prompt": "requirements_analyst_agent.md",
  "tools": [
    "@confluence/*",
    "@github/*",
    "@jira/*",
    "@mywiki/*",
    "fs_read",
    "grep"
  ],
  "mcpServers": {
    "jira": {
      "command": "node",
      "args": [
        "$HOME/.kiro/tools/mcp-servers/jira-mcp/build/index.js"
      ],
      "cwd": "$HOME/.kiro/tools/mcp-servers/jira-mcp"
    },
    "confluence": {
      "command": "node",
      "args": [
        "$HOME/.kiro/tools/mcp-servers/confluence-mcp/build/index.js"
      ],
      "cwd": "$HOME/.kiro/tools/mcp-servers/confluence-mcp"
    },
    "github": {
      "command": "node",
      "args": [
        "$HOME/.kiro/tools/mcp-servers/github-mcp/build/index.js"
      ],
      "cwd": "$HOME/.kiro/tools/mcp-servers/github-mcp"
    },
    "mywiki": {
      "command": "node",
      "args": [
        "$HOME/.kiro/tools/mcp-servers/confluence-mcp/build/index.js"
      ],
      "cwd": "$HOME/.kiro/tools/mcp-servers/confluence-mcp",
      "env": {
        "CONFLUENCE_URL": "https://mywiki.disney.com",
        "CONFLUENCE_PAT": "YOUR_TOKEN"
      }
    }
  },
  "allowedTools": [
    "@confluence/*",
    "@github/*",
    "@jira/*",
    "@mywiki/*"
  ],
  "resources": [
    "file://.kiro/context/ba_guidelines.md"
  ]
}
