{
  "name": "ba_orchestrator_agent",
  "description": "Orchestrates BA/PO tasks and coordinates specialized agents for requirements, scope, and feature definition",
  "prompt": "ba_orchestrator_agent.md",
  "tools": [
    "@confluence/*",
    "@github/*",
    "@jira/*",
    "@mywiki/*",
    "fs_read",
    "fs_write",
    "grep",
    "use_subagent",
    "thinking",
    "todo",
    "delegate"
  ],
  "mcpServers": {
    "jira": {
      "command": "node",
      "args": [
        "$HOME/.kiro/tools/mcp-servers/jira-mcp/dist/index.cjs"
      ],
      "env": {
        "JIRA_PAT": "YOUR_TOKEN"
      }
    },
    "confluence": {
      "command": "node",
      "args": [
        "$HOME/.kiro/tools/mcp-servers/confluence-mcp/dist/index.cjs"
      ],
      "env": {
        "CONFLUENCE_URL": "https://confluence.disney.com",
        "CONFLUENCE_PAT": "YOUR_TOKEN"
      }
    },
    "github": {
      "command": "node",
      "args": [
        "$HOME/.kiro/tools/mcp-servers/github-mcp/dist/index.cjs"
      ],
      "env": {
        "GITHUB_TOKEN_disney": "YOUR_TOKEN",
        "GITHUB_HOST_disney": "github.disney.com",
        "GITHUB_DEFAULT_REMOTE": "disney"
      }
    },
    "mywiki": {
      "command": "node",
      "args": [
        "$HOME/.kiro/tools/mcp-servers/confluence-mcp/dist/index.cjs"
      ],
      "env": {
        "CONFLUENCE_URL": "https://mywiki.disney.com",
        "CONFLUENCE_PAT": "YOUR_TOKEN"
      }
    }
  },
  "allowedTools": [
    "@confluence/*",
    "@github/*",
    "@jira/*",
    "@mywiki/*"
  ],
  "resources": [
    "file://.kiro/context/ba_guidelines.md"
  ],
  "includeMcpJson": true,
  "welcomeMessage": "\ud83d\udc4b BA/PO orchestrator ready!\n\nI can help you:\n  \u2022 Gather and analyze requirements from Jira epics\n  \u2022 Define scope boundaries and constraints\n  \u2022 Write user stories with acceptance criteria\n  \u2022 Validate requirements completeness\n\nTry: \"Analyze requirements for DPAY-500\"",
  "hooks": {
    "agentSpawn": [
      {
        "command": "$HOME/.kiro/hooks/git-context.sh",
        "description": "Inject git branch and status"
      }
    ]
  }
}
