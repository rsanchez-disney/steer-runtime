{
  "name": "scope_definer_agent",
  "description": "Defines project and feature scope by analyzing requirements, stakeholder needs, and constraints",
  "prompt": "scope_definer_agent.md",
  "tools": [
    "@confluence/*",
    "@github/*",
    "@jira/*",
    "fs_read",
    "fs_write",
    "grep"
  ],
  "mcpServers": {
    "jira": {
      "command": "node",
      "args": [
        "$HOME/.kiro/tools/mcp-servers/jira-mcp/build/index.js"
      ],
      "cwd": "$HOME/.kiro/tools/mcp-servers/jira-mcp"
    },
    "confluence": {
      "command": "node",
      "args": [
        "$HOME/.kiro/tools/mcp-servers/confluence-mcp/build/index.js"
      ],
      "cwd": "$HOME/.kiro/tools/mcp-servers/confluence-mcp"
    },
    "github": {
      "command": "node",
      "args": [
        "$HOME/.kiro/tools/mcp-servers/github-mcp/build/index.js"
      ],
      "cwd": "$HOME/.kiro/tools/mcp-servers/github-mcp"
    }
  },
  "allowedTools": [
    "@jira/*",
    "@confluence/*",
    "@github/*"
  ],
  "resources": [
    "file://.kiro/context/ba_guidelines.md"
  ]
}
