{
  "name": "webapi",
  "description": "Config Studio WebAPI specialist (Node gateway)",
  "prompt": "webapi.md",
  "tools": [
    "fs_read",
    "fs_write",
    "execute_bash",
    "@context7/*",
    "@bruno/*"
  ],
  "toolsSettings": {
    "fs_write": {
      "allowedPaths": [
        "src/**",
        "package.json",
        "tsconfig*.json",
        ".eslintrc*",
        "jest.config*"
      ]
    }
  },
  "resources": [
    "file://AGENTS.md",
    "file://.kiro/steering/**/*.md",
    "file://README.md"
  ],
  "hooks": {
    "preToolUse": [
      {
        "matcher": "fs_write",
        "command": "$HOME/.kiro/hooks/guard-writes.sh",
        "description": "Block writes to node_modules, dist, .git"
      },
      {
        "matcher": "fs_write",
        "command": "$HOME/.kiro/hooks/secret-scan.sh",
        "description": "Scan for potential secrets before writing"
      }
    ],
    "postToolUse": [
      {
        "matcher": "fs_write",
        "command": "$HOME/.kiro/hooks/lint-on-write.sh",
        "description": "Auto-lint after file writes"
      }
    ]
  },
  "mcpServers": {
    "context7": {
      "command": "npx",
      "args": [
        "-y",
        "@upstash/context7-mcp"
      ]
    },
    "bruno": {
      "command": "node",
      "args": [
        "$HOME/.kiro/tools/mcp-servers/bruno-mcp/dist/index.cjs"
      ]
    }
  },
  "allowedTools": [
    "@context7/*",
    "@bruno/*"
  ],
  "includeMcpJson": true
}
