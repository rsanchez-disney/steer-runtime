{
  "name": "story_analyzer_agent",
  "description": "Fetches and analyzes Jira stories. Extracts scope, acceptance criteria, and metadata.",
  "prompt": "story_analyzer_agent.md",
  "tools": [
    "web_fetch",
    "grep",
    "fs_read",
    "@jira/*",
    "@confluence/*",
    "@github/*"
  ],
  "mcpServers": {
    "mcp-atlassian": {
      "command": "docker",
      "args": [
        "run",
        "-i",
        "--rm",
        "-e",
        "JIRA_URL=https://myjira.disney.com",
        "-e",
        "CONFLUENCE_URL=https://confluence.disney.com",
        "-e",
        "JIRA_SSL_VERIFY=false",
        "-e",
        "CONFLUENCE_SSL_VERIFY=false",
        "-e",
        "JIRA_PERSONAL_TOKEN=Njc3MzQ2MjA1MDQzOjI0peko0okp8hd1Gn7mUdJRn37k",
        "-e",
        "CONFLUENCE_PERSONAL_TOKEN=Mjg2NTcwMTA1MjI5Otsr9OxkquCCCiK4gQtN8QonAK4W",
        "containerregistry.disney.com/jedaimcp/jedai/mcp-atlassian:v0.13.0"
      ],
      "env": {
        "": ""
      },
      "timeout": 60000,
      "disabled": false
    },
    "github": {
      "command": "node",
      "args": [
        "/Users/ricardo.sanchez/.kiro/tools/mcp-servers/github-mcp/build/index.js"
      ],
      "cwd": "/Users/ricardo.sanchez/.kiro/tools/mcp-servers/github-mcp"
    }
  },
  "allowedTools": [
    "@jira/*",
    "@confluence/*",
    "@github/*"
  ],
  "resources": [
    "file://.kiro/context/project_mappings.md",
    "file://.kiro/steering/**/*.md"
  ]
}
