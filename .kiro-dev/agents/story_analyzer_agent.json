{
  "name": "story_analyzer_agent",
  "description": "Fetches and analyzes Jira stories. Extracts scope, acceptance criteria, and metadata.",
  "prompt": "story_analyzer_agent.md",
  "tools": [
    "web_fetch",
    "grep",
    "fs_read",
    "@jira/*",
    "@confluence/*",
    "@github/*"
  ],
  "mcpServers": {
    "jira": {
      "command": "node",
      "args": [
        "$HOME/.kiro/tools/mcp-servers/jira-mcp/build/index.js"
      ],
      "cwd": "$HOME/.kiro/tools/mcp-servers/jira-mcp"
    },
    "confluence": {
      "command": "node",
      "args": [
        "$HOME/.kiro/tools/mcp-servers/confluence-mcp/build/index.js"
      ],
      "cwd": "$HOME/.kiro/tools/mcp-servers/confluence-mcp"
    },
    "mcp-atlassian": {
      "command": "docker",
      "args": [
        "run", "-i", "--rm",
        "-e", "JIRA_URL",
        "-e", "CONFLUENCE_URL",
        "-e", "JIRA_SSL_VERIFY",
        "-e", "CONFLUENCE_SSL_VERIFY",
        "-e", "JIRA_PERSONAL_TOKEN",
        "-e", "CONFLUENCE_PERSONAL_TOKEN",
        "ghcr.io/sooperset/mcp-atlassian:latest"
      ],
      "env": {
        "JIRA_URL": "https://myjira.disney.com",
        "JIRA_PERSONAL_TOKEN": "YOUR_TOKEN",
        "JIRA_SSL_VERIFY": "false",
        "CONFLUENCE_URL": "https://confluence.disney.com",
        "CONFLUENCE_PERSONAL_TOKEN": "YOUR_TOKEN",
        "CONFLUENCE_SSL_VERIFY": "false"
      },
      "timeout": 60000,
      "disabled": true
    },
    "github": {
      "command": "node",
      "args": [
        "$HOME/.kiro/tools/mcp-servers/github-mcp/build/index.js"
      ],
      "cwd": "$HOME/.kiro/tools/mcp-servers/github-mcp"
    }
  },
  "allowedTools": [
    "@jira/*",
    "@confluence/*",
    "@github/*"
  ],
  "resources": [
    "file://.kiro/context/project_mappings.md",
    "file://.kiro/steering/**/*.md"
  ]
}
