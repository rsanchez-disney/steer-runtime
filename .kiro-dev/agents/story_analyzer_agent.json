{
  "name": "story_analyzer_agent",
  "description": "Fetches and analyzes Jira stories, Confluence pages, and GitHub repos.",
  "prompt": "story_analyzer_agent.md",
  "tools": [
    "@confluence/*",
    "@github/*",
    "@jira/*",
    "@mywiki/*",
    "fs_read",
    "grep",
    "web_fetch",
    "knowledge"
  ],
  "mcpServers": {
    "jira": {
      "command": "node",
      "args": [
        "$HOME/.kiro/tools/mcp-servers/jira-mcp/dist/index.cjs"
      ],
      "env": {
        "JIRA_PAT": "YOUR_TOKEN"
      }
    },
    "confluence": {
      "command": "node",
      "args": [
        "$HOME/.kiro/tools/mcp-servers/confluence-mcp/dist/index.cjs"
      ],
      "env": {
        "CONFLUENCE_URL": "https://confluence.disney.com",
        "CONFLUENCE_PAT": "YOUR_TOKEN"
      }
    },
    "mcp-atlassian": {
      "command": "docker",
      "args": [
        "run",
        "-i",
        "--rm",
        "-e",
        "JIRA_URL",
        "-e",
        "CONFLUENCE_URL",
        "-e",
        "JIRA_SSL_VERIFY",
        "-e",
        "CONFLUENCE_SSL_VERIFY",
        "-e",
        "JIRA_PERSONAL_TOKEN",
        "-e",
        "CONFLUENCE_PERSONAL_TOKEN",
        "ghcr.io/sooperset/mcp-atlassian:latest"
      ],
      "env": {
        "JIRA_URL": "https://myjira.disney.com",
        "JIRA_PERSONAL_TOKEN": "JIRA_PERSONAL_TOKEN",
        "JIRA_SSL_VERIFY": "false",
        "CONFLUENCE_URL": "https://confluence.disney.com",
        "CONFLUENCE_PERSONAL_TOKEN": "CONFLUENCE_PERSONAL_TOKEN",
        "CONFLUENCE_SSL_VERIFY": "false"
      },
      "timeout": 60000,
      "disabled": true
    },
    "github": {
      "command": "node",
      "args": [
        "$HOME/.kiro/tools/mcp-servers/github-mcp/dist/index.cjs"
      ],
      "env": {
        "GITHUB_TOKEN_disney": "YOUR_TOKEN",
        "GITHUB_HOST_disney": "github.disney.com",
        "GITHUB_DEFAULT_REMOTE": "disney"
      }
    },
    "mywiki": {
      "command": "node",
      "args": [
        "$HOME/.kiro/tools/mcp-servers/confluence-mcp/dist/index.cjs"
      ],
      "env": {
        "CONFLUENCE_URL": "https://mywiki.disney.com",
        "CONFLUENCE_PAT": "YOUR_TOKEN"
      }
    }
  },
  "allowedTools": [
    "@confluence/*",
    "@github/*",
    "@jira/*",
    "@mywiki/*"
  ],
  "resources": [
    "file://.kiro/context/project_mappings.md",
    "file://.kiro/steering/**/*.md"
  ],
  "includeMcpJson": true
}
