{
  "name": "ui",
  "description": "Config Studio UI specialist (Angular)",
  "prompt": "ui.md",
  "tools": [
    "read",
    "write",
    "shell"
  ],
  "toolsSettings": {
    "write": {
      "allowedPaths": [
        "src/**",
        "projects/**",
        "package.json",
        "angular.json",
        ".eslintrc*",
        "tsconfig*.json"
      ]
    }
  },
  "resources": [
    "file://AGENTS.md",
    "file://.kiro/steering/**/*.md",
    "file://README.md"
  ],
  "hooks": {
    "preToolUse": [
      {
        "matcher": "fs_write",
        "command": "$HOME/.kiro/hooks/guard-writes.sh",
        "description": "Block writes to node_modules, dist, .git"
      }
    ]
  }
}
