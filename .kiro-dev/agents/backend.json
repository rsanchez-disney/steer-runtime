{
  "name": "backend",
  "description": "Backend specialist for Java, Rust, Go, and Python services",
  "prompt": "backend.md",
  "tools": [
    "read",
    "write",
    "shell"
  ],
  "toolsSettings": {
    "write": {
      "allowedPaths": [
        "src/**",
        "pom.xml",
        "build.gradle*",
        "gradle.properties",
        "application*.yml",
        "application*.yaml",
        "Cargo.toml",
        "Cargo.lock",
        "go.mod",
        "go.sum",
        "*.go",
        "cmd/**",
        "internal/**",
        "pkg/**",
        "requirements.txt",
        "pyproject.toml",
        "setup.py",
        "setup.cfg",
        "*.py",
        "*.rs"
      ]
    }
  },
  "resources": [
    "file://AGENTS.md",
    "file://.kiro/steering/**/*.md",
    "file://README.md"
  ]
}
