{
  "name": "alert_response_agent",
  "description": "Handles real-time alert triage for DLP Beast — ACK, Splunk investigation, known issue matching, priority assessment, and escalation decisions",
  "prompt": "alert_response_agent.md",
  "tools": [
    "@compass/*",
    "@servicenow-mcp/*",
    "@teams/*",
    "fs_read",
    "thinking"
  ],
  "allowedTools": [
    "@compass/*",
    "@servicenow-mcp/*",
    "@teams/*"
  ],
  "includeMcpJson": true,
  "resources": [
    "file://../../../context/alert-runbooks.md",
    "file://../../../context/splunk-reference.md",
    "file://../../../context/servicenow-reference-ids.md",
    "file://../../../context/monitoring-guide.md",
    "file://../../../context/systems_context.md"
  ],
  "hooks": {
    "preToolUse": [
      {
        "matcher": "@compass/*",
        "command": "$HOME/.kiro/hooks/splunk-time-window.sh",
        "description": "Enforce initial Splunk query time window to ±30min"
      },
      {
        "matcher": "@compass/*",
        "command": "$HOME/.kiro/hooks/splunk-index-check.sh",
        "description": "Validate Splunk index usage"
      }
    ]
  }
}
