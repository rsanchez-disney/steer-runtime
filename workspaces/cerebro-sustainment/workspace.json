{
  "name": "cerebro-sustainment",
  "description": "ADM PCS · DX Profile — Incident management & triage agent for sustainment operations",
  "team": "ADM PCS / DX Profile (Cerebro)",
  "profiles": ["sustainment", "ops", "dev-core"],
  "default_agent": "sustainment_orchestrator_agent",
  "rules": ["cerebro-incident-response"],
  "enable_tools": true,
  "jira_prefix": "ADMPROFILE-",
  "workspace_path": "${WORKSPACE_ROOT}/cerebro",
  "catalog_scope": "profiles/sustainment/managed-services-catalog/studios/studio-cerebro",
  "hooks": {
    "on_agent_spawn": {
      "action": "load_catalog_context",
      "description": "Pre-load BAPP info for studio-cerebro from managed-services-catalog",
      "catalog_path": "profiles/sustainment/managed-services-catalog/studios/studio-cerebro",
      "load_fields": ["app.yaml", "runbook.md", "troubleshooting.md"]
    }
  },
  "projects": [
    {
      "name": "dx-profile-webapi",
      "path": "profile-webapi",
      "repo": "profile-vertical/profile-webapi"
    },
    {
      "name": "profile-spa",
      "path": "profile-spa",
      "repo": "profile-vertical/profile-spa"
    },
    {
      "name": "sustainment-toolkit",
      "path": "sustainment-toolkit",
      "repo": "MARIS117/sustainment-toolkit"
    }
  ],
  "services": [
    "dx-profile-web",
    "dx-profile-api",
    "config-services",
    "photo-services",
    "vas-integration",
    "content-publisher",
    "facilities-publisher",
    "characters-publisher",
    "facility-status"
  ]
}
