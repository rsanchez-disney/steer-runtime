{
  "name": "chrome-devtools-mcp-bundle",
  "version": "1.0.0",
  "type": "module",
  "description": "MCP bundle wrapping chrome-devtools-mcp — headless Chrome automation for coding agents",
  "private": true,
  "main": "dist/index.cjs",
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --format=cjs --outfile=dist/index.cjs --banner:js='#!/usr/bin/env node' --external:node:* && chmod 755 dist/index.cjs",
    "postinstall": "npm run build"
  },
  "dependencies": {
    "chrome-devtools-mcp": "^1.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "esbuild": "^0.21.0",
    "typescript": "^5.0.0"
  },
  "bin": {
    "chrome-devtools-mcp-bundle": "dist/index.cjs"
  }
}
