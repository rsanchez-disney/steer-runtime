{
  "name": "ui",
  "description": "Config Studio UI specialist (Angular) — OpSheet+ team",
  "prompt": "webui-developer.md",
  "tools": [
    "fs_read",
    "fs_write",
    "execute_bash",
    "code",
    "grep",
    "@figma/*"
  ],
  "toolsSettings": {
    "fs_write": {
      "allowedPaths": [
        "src/**",
        "projects/**",
        "package.json",
        "angular.json",
        ".eslintrc*",
        "tsconfig*.json",
        ".kiro/ticket-cache/**"
      ]
    }
  },
  "resources": [
    "file://AGENTS.md",
    "file://README.md",
    "file://.kiro/steering/**/*.md",
    "file://.kiro/context/angular_modern_patterns.md"
  ],
  "steering": [
    "steering/ui-angular-opsheet.md",
    "steering/opsheet-angular-reviewer.md"
  ],
  "skills": [
    "skills/opsheet-ui-feature-implementation.md",
    "skills/opsheet-ui-bugfix.md"
  ],
  "hooks": {
    "preToolUse": [
      {
        "matcher": "fs_write",
        "command": "$HOME/.kiro/hooks/guard-writes.sh",
        "description": "Block writes to node_modules, dist, .git"
      },
      {
        "matcher": "fs_write",
        "command": "$HOME/.kiro/hooks/secret-scan.sh",
        "description": "Scan for potential secrets before writing"
      }
    ],
    "postToolUse": [
      {
        "matcher": "fs_write",
        "command": "$HOME/.kiro/hooks/lint-on-write.sh",
        "description": "Auto-lint after file writes"
      }
    ]
  },
  "allowedTools": [
    "@figma/*"
  ],
  "includeMcpJson": true
}