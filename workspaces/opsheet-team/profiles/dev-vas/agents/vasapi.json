{
  "name": "vasapi",
  "description": "Opsheet Plus VAS API specialist (Koa/TypeScript)",
  "prompt": "vasapi.md",
  "tools": [
    "fs_read",
    "fs_write",
    "execute_bash",
    "@bruno/*"
  ],
  "toolsSettings": {
    "fs_write": {
      "allowedPaths": [
        "src/**",
        "env/**",
        "package.json",
        "tsconfig*.json",
        ".eslintrc*",
        "jest.config*",
        ".prettierrc",
        ".lintstagedrc"
      ]
    }
  },
  "resources": [
    "file://AGENTS.md",
    "file://.kiro/steering/**/*.md",
    "file://README.md"
  ],
  "hooks": {
    "preToolUse": [
      {
        "matcher": "fs_write",
        "command": "$HOME/.kiro/hooks/guard-writes.sh",
        "description": "Block writes to node_modules, dist, .git"
      },
      {
        "matcher": "fs_write",
        "command": "$HOME/.kiro/hooks/secret-scan.sh",
        "description": "Scan for potential secrets before writing"
      }
    ],
    "postToolUse": [
      {
        "matcher": "fs_write",
        "command": "$HOME/.kiro/hooks/lint-on-write.sh",
        "description": "Auto-lint after file writes"
      }
    ]
  },
  "allowedTools": [
    "@bruno/*"
  ],
  "includeMcpJson": true
}
