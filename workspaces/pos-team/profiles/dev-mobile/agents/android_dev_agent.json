{
  "name": "android_dev_agent",
  "description": "Android Developer \u2014 implements features and fixes following project conventions. Manages Jira tickets for POS project.",
  "prompt": "file://../prompts/android_dev_agent.md",
  "tools": [
    "fs_read",
    "fs_write",
    "code",
    "grep",
    "glob",
    "execute_bash",
    "@gitlab/*",
    "@jira/*",
    "@jira-cloud/*"
  ],
  "resources": [
    "file://../../../context/team_context.md",
    "file://../../../context/testing_conventions.md",
    "file://../../../context/golden_rules.md",
    "file://../../../context/memory-bank/*",
    "file://../../../context/hilt_guidelines.md",
    "file://../../../skills/implement-android-ticket/SKILL.md",
    "file://../../../skills/epic-qa-workflow/SKILL.md"
  ],
  "hooks": {
    "preToolUse": [
      {
        "matcher": "fs_write",
        "command": "~/.kiro/hooks/guard-writes.sh",
        "description": "Block writes to build/, .gradle/, .git/"
      }
    ]
  },
  "includeMcpJson": true
}
