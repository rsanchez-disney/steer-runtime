{
  "name": "android_dev_agent",
  "description": "Android Developer \u2014 implements features and fixes following project conventions. Manages Jira tickets for POS project.",
  "prompt": "prompts/android_dev_agent.md",
  "tools": [
    "fs_read",
    "fs_write",
    "code",
    "grep",
    "glob",
    "execute_bash",
    "@gitlab/*",
    "@jira/*",
    "@jira-cloud/*"
  ],
  "resources": [
    "file://.kiro/steer-runtime/workspaces/pos-team/context/team_context.md",
    "file://.kiro/steer-runtime/workspaces/pos-team/context/testing_conventions.md",
    "file://.kiro/steer-runtime/workspaces/pos-team/context/golden_rules.md",
    "file://.kiro/steer-runtime/workspaces/pos-team/context/memory-bank/learnings.md",
    "file://.kiro/steer-runtime/workspaces/pos-team/context/hilt_guidelines.md"
  ],
  "hooks": {
    "preToolUse": [
      {
        "matcher": "fs_write",
        "command": "~/.kiro/hooks/guard-writes.sh",
        "description": "Block writes to build/, .gradle/, .git/"
      }
    ]
  },
  "includeMcpJson": true
}
