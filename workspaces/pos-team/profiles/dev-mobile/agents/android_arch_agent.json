{
  "name": "android_arch_agent",
  "description": "Android Architect — primary orchestrator for POS team. Decomposes tasks and delegates to Dev, Test, Quality, and PR agents.",
  "prompt": "prompts/android_arch_agent.md",
  "tools": [
    "fs_read",
    "fs_write",
    "@gitlab/*",
    "@jira/*",
    "execute_bash",
    "grep",
    "glob",
    "code",
    "thinking",
    "todo_list",
    "subagent"
  ],
  "toolsSettings": {
    "subagent": {
      "availableAgents": [
        "requirements_analyst_agent",
        "sprint_manager_agent",
        "android_dev_agent",
        "android_test_agent",
        "android_quality_agent",
        "android_pr_agent"
      ],
      "trustedAgents": [
        "android_dev_agent",
        "android_test_agent",
        "android_quality_agent",
        "android_pr_agent"
      ]
    },
    "execute_bash": {
      "allowedCommands": [
        "./gradlew --console=plain *"
      ]
    }
  },
  "resources": [
    "file://.kiro/steer-runtime/workspaces/pos-team/context/team_context.md",
    "file://.kiro/steer-runtime/workspaces/pos-team/context/testing_conventions.md",
    "file://.kiro/steer-runtime/workspaces/pos-team/context/golden_rules.md",
    "file://.kiro/steer-runtime/workspaces/pos-team/context/memory-bank/learnings.md",
    "file://.kiro/steer-runtime/workspaces/pos-team/context/hilt_guidelines.md"
  ],
  "hooks": {
    "agentSpawn": [
      {
        "command": "~/.kiro/hooks/git-context.sh",
        "description": "Inject git branch and status"
      }
    ],
    "preToolUse": [
      {
        "matcher": "fs_write",
        "command": "~/.kiro/hooks/guard-writes.sh",
        "description": "Block writes to build/, .gradle/, .git/"
      }
    ]
  },
  "welcomeMessage": "Android Architect ready. Describe the feature or task and I'll orchestrate the implementation through Dev, Test, Quality, and PR agents."
}
