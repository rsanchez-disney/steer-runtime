{
  "name": "sdet_agent",
  "description": "SDET agent specialized in test automation, framework analysis, and QA engineering tasks for the POS automation framework with Jira Cloud integration",
  "prompt": "file://../prompts/sdet_agent.md",
  "tools": [
    "fs_read",
    "fs_write",
    "code",
    "grep",
    "glob",
    "execute_bash",
    "@gitlab/*",
    "@jira/*",
    "@jira-cloud/*",
    "@confluence-cloud/*"
  ],
  "resources": [
    "file://../../../context/team_context.md",
    "file://../../../context/testing_conventions.md",
    "file://../../../context/golden_rules.md",
    "file://../../../context/memory-bank/*",
    "file://../../../context/hilt_guidelines.md",
    "file://../../../skills/automate-pos-scenarios/SKILL.md"
  ],
  "hooks": {
    "preToolUse": [
      {
        "matcher": "fs_write",
        "command": "~/.kiro/hooks/guard-writes.sh",
        "description": "Block writes to build/, .gradle/, .git/"
      }
    ]
  },
  "includeMcpJson": true
}
