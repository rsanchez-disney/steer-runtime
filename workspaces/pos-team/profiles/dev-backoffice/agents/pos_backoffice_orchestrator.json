{
  "name": "pos_backoffice_orchestrator",
  "description": "POS Backoffice SDLC orchestrator — 7-stage workflow for PHP, Go, and React projects",
  "prompt": "file://../prompts/pos_backoffice_orchestrator.md",
  "tools": [
    "thinking",
    "knowledge",
    "todo_list",
    "subagent",
    "@mermaid/*"
  ],
  "toolsSettings": {
    "subagent": {
      "availableAgents": [
        "pos_architecture_agent",
        "pos_codebase_explorer_agent",
        "pos_go_agent",
        "pos_php_agent",
        "pos_react_agent",
        "pos_test_runner_agent",
        "pos_planner_agent",
        "pos_security_scanner_agent",
        "pos_work_documenter_agent",
        "pos_code_review_agent",
        "pos_story_analyzer_agent"
      ],
      "trustedAgents": [
        "pos_architecture_agent",
        "pos_codebase_explorer_agent",
        "pos_go_agent",
        "pos_php_agent",
        "pos_react_agent",
        "pos_test_runner_agent",
        "pos_planner_agent",
        "pos_security_scanner_agent",
        "pos_work_documenter_agent",
        "pos_code_review_agent",
        "pos_story_analyzer_agent"
      ]
    }
  },
  "resources": [
    "file://.kiro/context/backoffice_golden_rules.md",
    "file://.kiro/steering/**/*.md",
    "file://../../../context/features/README.md"
  ],
  "hooks": {
    "agentSpawn": [
      {
        "command": "$HOME/.kiro/hooks/git-context.sh",
        "description": "Inject git branch and status"
      },
      {
        "command": "$HOME/.kiro/hooks/agent-registry.sh",
        "description": "Inject available agents registry for dynamic delegation"
      },
      {
        "command": "$HOME/.kiro/hooks/delegation-map.sh",
        "description": "Generate delegation map for routing decisions"
      }
    ],
    "stop": [
      {
        "command": "$HOME/.kiro/hooks/session-summary.sh",
        "description": "Log session telemetry to JSONL"
      },
      {
        "command": "$HOME/.kiro/hooks/session-to-memory.sh",
        "description": "Update active-context.md with session summary"
      }
    ]
  },
  "welcomeMessage": "🏗️ POS Backoffice Orchestrator ready!\n\nI provide architecture guidance AND orchestrate backoffice development:\n  • Architecture decisions, design reviews, system analysis\n  • Delegate implementation to PHP, Go, or React specialists\n  • Route code reviews, tests, security scans, and planning\n\nDescribe your task or give me a Jira ticket and I'll handle it.",
  "includeMcpJson": true
}
