{
  "name": "pos_react_agent",
  "description": "React/TypeScript frontend specialist for the Connect SPA — React 17, Redux/RTK, MUI 5, Jest",
  "prompt": "file://../prompts/pos_react_agent.md",
  "tools": [
    "fs_read",
    "fs_write",
    "execute_bash",
    "code",
    "grep"
  ],
  "allowedTools": [],
  "resources": [
    "file://.kiro/context/backoffice_golden_rules.md",
    "file://.kiro/context/security_golden_rules.md",
    "file://.kiro/steering/**/*.md"
  ],
  "includeMcpJson": true,
  "hooks": {
    "preToolUse": [
      {
        "matcher": "fs_write",
        "command": "$HOME/.kiro/hooks/guard-writes.sh",
        "description": "Block writes to node_modules, .git"
      },
      {
        "matcher": "fs_write",
        "command": "$HOME/.kiro/hooks/secret-scan.sh",
        "description": "Scan for potential secrets before writing"
      }
    ],
    "postToolUse": [
      {
        "matcher": "fs_write",
        "command": "$HOME/.kiro/hooks/lint-on-write.sh",
        "description": "Auto-lint after file writes"
      }
    ]
  },
  "welcomeMessage": "Ready for React/TypeScript frontend development. Point me to your component or describe the task."
}
