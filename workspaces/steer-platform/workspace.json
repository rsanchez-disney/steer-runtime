{
  "name": "steer-platform",
  "description": "Development workspace for the steer ecosystem \u2014 runtime, Koda, Kite, Mouseketool, plugins, scoring",
  "team": "Steer Platform",
  "profiles": [
    "dev-core",
    "dev-web",
    "qa",
    "ops",
    "steer-master"
  ],
  "default_agent": "steer_orchestrator_agent",
  "projects": [
    {
      "name": "steer-runtime",
