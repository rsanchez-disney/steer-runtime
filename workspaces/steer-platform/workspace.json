      "host": "github.disney.com"
    },
    {
      "name": "Koda",
      "repo": "SANCR225/Koda",
      "path": "Koda",
      "host": "github.disney.com"
    },
    {
      "name": "Kite",
      "repo": "SANCR225/Kite",
      "path": "Kite",
      "host": "github.disney.com"
    },
    {
      "name": "Mouseketool",
      "repo": "SANCR225/mouseketool",
      "path": "mouseketool",
      "host": "github.disney.com"
    },
    {
      "name": "prompt-score",
      "repo": "SANCR225/prompt-score",
      "path": "prompt-score",
      "host": "github.disney.com"
    },
    {
      "name": "steer-autopilot",
      "repo": "SANCR225/steer-autopilot",
      "path": "steer-autopilot",
      "host": "github.disney.com"
    },
    {
      "name": "steer-plugins",
      "repo": "SANCR225/steer-plugins",
      "path": "steer-plugins",
      "host": "github.disney.com"
    },
    {
      "name": "delivery-command-center",
      "repo": "ZAPAJ024/delivery-command-center",
      "path": "delivery-command-center",
      "host": "github.disney.com"
    },
    {
      "name": "KodaSDK",
      "repo": "SANCR225/KodaSDK",
      "path": "KodaSDK",
      "host": "github.disney.com"
    }
  ],
  "rules": [
    "conventional_commit",
    "general-go-development",
    "general-node-development",
    "general-react-development"
  ],
  "enable_tools": true,
  "workspace_path": "${WORKSPACE_ROOT}/Disney/SANCR225"
