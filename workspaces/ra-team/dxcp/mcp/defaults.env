# DXCP Workspace MCP Defaults
# Non-secret team-shared defaults (committed to repo)
# Secrets go in ~/.kiro/tokens.env (never committed)

# Jira (Cloud instance - Level 1 global, configured via koda tokens)
JIRA_HOST=disneyexperiences.atlassian.net
JIRA_PROJECT=IOET

# GitHub Enterprise (Level 1 global, configured via koda tokens)
GITHUB_HOST=github.disney.com

# Harness (Level 3 workspace)
DXCP_HARNESS_BASE_URL=https://disney.harness.io

# ServiceNow (Level 3 workspace)
DXCP_SERVICENOW_URL=https://disney.service-now.com

# Splunk (Level 3 workspace)
DXCP_SPLUNK_BASE_URL=https://splunk.api.wdprapps.disney.com

# Rundeck (used by scripts, not MCP)
RUNDECK_URL=https://rundeck.wdprapps.disney.com
RUNDECK_API_VERSION=52

# Rafay (used by scripts, not MCP)
RAFAY_API_BASE=https://console.rafay.dev
