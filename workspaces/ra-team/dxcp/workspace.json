  "rules": [
    "+general-kubernetes",
    "+general-terraform",
    "+general-aws",
    "+general-docker"
  ],
  "enable_tools": true,
  "jira_prefix": "IOET-",
  "jira_host": "disneyexperiences.atlassian.net",
  "workspace_path": "~/dxcp/other",
  "services": [
    "rafay-gitops",
    "eks-clusters",
    "gke-clusters",
    "helm-addons",
    "rundeck-jobs",
    "terraform-infra",
    "cluster-configurator",
    "dxcp-spog"
  ],
  "exclusive_overrides": {
    "cloudops": [
      "skills",
      "steering"
    ]
  }
