{
  "studio": "dotnet",
  "projectName": "<YOUR_PROJECT_NAME>",
  "projectArchetype": "self-host-api",
  "deploymentTarget": "<windows-service|kubernetes|ecs>",
  "targetProjectPath": "<PATH_TO_YOUR_PROJECT>",
  "companyCommonLibraryPath": "<PATH_TO_COMPANY_COMMON_LIBRARY>",
  "referenceProjectPath": "<PATH_TO_REFERENCE_PROJECT>",
  "companyCommonRegistrationPreference": "auto-detect",
  "awsMode": "mock-friendly",
  "testing": {
    "framework": "xunit",
    "coverageTarget": 90
  },
  "swagger": {
    "enabled": true,
    "xmlComments": true
  }
}
