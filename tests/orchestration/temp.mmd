graph TB
    subgraph "Route 53 DNS"
        DNS1[payment-controls-api-env.wdprapps.disney.com]
        DNS2[validation-service-env.wdprapps.disney.com]
        DNS3[refund-service-env.wdprapps.disney.com]
    end

    subgraph "Application Load Balancers"
        ALB_PUB[Public ALB\nExternal-facing]
        ALB_INT[Internal ALB\nService-to-service]
    end

    subgraph "ECS Cluster: payment-controls"
        subgraph "Gateway Service"
            GW1[Task 1\n512MB / 0.25 vCPU]
            GW2[Task 2\n512MB / 0.25 vCPU]
        end

        subgraph "Validation Service"
            VS1[Task 1\n1GB / 0.5 vCPU]
            VS2[Task 2\n1GB / 0.5 vCPU]
            VS3[Task 3\n1GB / 0.5 vCPU]
            VSN[... up to 12]
        end

        subgraph "Refund Service"
            RS1[Task 1\n2GB / 1 vCPU]
            RS2[Task 2\n2GB / 1 vCPU]
            RSN[... up to 8]
        end
    end

    DNS1 --> ALB_PUB
    DNS2 --> ALB_INT
    DNS3 --> ALB_INT

    ALB_PUB -->|all traffic| GW1
    ALB_PUB -->|all traffic| GW2
    ALB_INT -->|/validations| VS1
    ALB_INT -->|/validations| VS2
    ALB_INT -->|/validations| VS3
    ALB_INT -->|/exports /refunds| RS1
    ALB_INT -->|/exports /refunds| RS2