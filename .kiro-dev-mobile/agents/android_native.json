{
  "name": "android_native",
  "description": "Android native specialist for Kotlin/Java and platform channels",
  "prompt": "android_native.md",
  "tools": [
    "fs_read",
    "fs_write",
    "execute_bash",
    "@context7/*"
  ],
  "toolsSettings": {
    "fs_write": {
      "allowedPaths": [
        "android/app/src/**",
        "android/build.gradle",
        "android/app/build.gradle",
        "android/gradle.properties",
        "android/settings.gradle",
        "android/app/src/main/AndroidManifest.xml"
      ]
    }
  },
  "resources": [
    "file://AGENTS.md",
    "file://.kiro/steering/**/*.md",
    "file://README.md"
  ],
  "mcpServers": {
    "context7": {
      "command": "npx",
      "args": [
        "-y",
        "@upstash/context7-mcp"
      ]
    }
  },
  "allowedTools": [
    "@context7/*"
  ],
  "includeMcpJson": true
}
