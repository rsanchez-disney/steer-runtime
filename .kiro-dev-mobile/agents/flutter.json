{
  "name": "flutter",
  "description": "Flutter/Dart specialist for cross-platform mobile development",
  "prompt": "flutter.md",
  "tools": [
    "fs_read",
    "fs_write",
    "execute_bash",
    "@context7/*"
  ],
  "toolsSettings": {
    "fs_write": {
      "allowedPaths": [
        "lib/**",
        "packages/*/lib/**",
        "packages/*/test/**",
        "test/**",
        "pubspec.yaml",
        "packages/*/pubspec.yaml",
        "analysis_options.yaml"
      ]
    }
  },
  "resources": [
    "file://AGENTS.md",
    "file://.kiro/steering/**/*.md",
    "file://README.md"
  ],
  "hooks": {
    "preToolUse": [
      {
        "matcher": "fs_write",
        "command": "$HOME/.kiro/hooks/guard-writes.sh",
        "description": "Block writes to node_modules, dist, .git"
      },
      {
        "matcher": "fs_write",
        "command": "$HOME/.kiro/hooks/secret-scan.sh",
        "description": "Scan for potential secrets before writing"
      }
    ],
    "postToolUse": [
      {
        "matcher": "fs_write",
        "command": "$HOME/.kiro/hooks/lint-on-write.sh",
        "description": "Auto-lint after file writes"
      }
    ]
  },
  "allowedTools": [
    "@context7/*"
  ],
  "includeMcpJson": true
}
