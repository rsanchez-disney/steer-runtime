# Confluence MCP Server Configuration
#
# CONFLUENCE_URL — your Confluence instance base URL
# Examples:
#   https://confluence.disney.com     (Disney Confluence)
#   https://disneyexperiences.atlassian.net/wiki         (Disney MyWiki)
#   https://your-domain.atlassian.net/wiki  (Atlassian Cloud)
CONFLUENCE_URL=https://confluence.disney.com

# Confluence Personal Access Token
CONFLUENCE_PAT=your_confluence_personal_access_token
