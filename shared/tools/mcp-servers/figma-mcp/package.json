{
  "name": "figma-mcp",
  "version": "0.1.0",
  "description": "Figma MCP server for fetching design files, components, styles, and comments",
  "private": true,
  "type": "module",
  "bin": {
    "figma-mcp": "./build/index.js"
  },
  "files": ["build"],
  "scripts": {
    "build": "tsc && node -e \"require('fs').chmodSync('build/index.js', '755')\"",
    "prepare": "npm run build",
    "watch": "tsc --watch"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "0.6.0",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "@types/node": "^20.11.24",
    "typescript": "^5.3.3"
  }
}
