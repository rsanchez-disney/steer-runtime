{
  "name": "mermaid-diagram-mcp",
  "version": "1.0.0",
  "type": "module",
  "description": "MCP server for generating images from Mermaid diagrams",
  "main": "dist/index.cjs",
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --format=cjs --outfile=dist/index.cjs --banner:js='#!/usr/bin/env node' --external:node:* && chmod 755 dist/index.cjs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "0.6.0",
    "@mermaid-js/mermaid-cli": "^10.6.1"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "esbuild": "^0.20.0",
    "typescript": "^5.0.0"
  },
  "bin": {
    "mermaid-diagram-mcp": "dist/index.cjs"
  }
}
