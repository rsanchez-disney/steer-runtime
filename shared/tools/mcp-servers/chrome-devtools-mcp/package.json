{
  "name": "chrome-devtools-mcp",
  "version": "1.0.0",
  "description": "Chrome DevTools MCP — headless browser automation via official chrome-devtools-mcp",
  "private": true,
  "type": "module",
  "main": "dist/index.cjs",
  "bin": {
    "chrome-devtools-mcp": "dist/index.cjs"
  },
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --format=cjs --outfile=dist/index.cjs --banner:js='#!/usr/bin/env node' --external:node:*",
    "postinstall": "npm run build"
  },
  "dependencies": {
    "chrome-devtools-mcp": "^1.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "esbuild": "^0.21.0",
    "typescript": "^5.0.0"
  }
}
