# JIRA MCP Server Configuration
#
# JIRA base URL — defaults to https://myjira.disney.com if not set.
# Override for a different Jira instance:
# JIRA_URL=https://jira.disney.com
JIRA_URL=https://myjira.disney.com

# JIRA Personal Access Token
# Get your token from: https://myjira.disney.com/secure/ViewProfile.jspa?selectedTab=com.atlassian.pats.pats-plugin:jira-user-personal-access-tokens
JIRA_PAT=your_jira_personal_access_token_here
