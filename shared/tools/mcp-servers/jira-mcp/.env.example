# JIRA MCP Server Configuration
#
# JIRA base URL — defaults to https://myjira.disney.com if not set.
JIRA_URL=https://myjira.disney.com

# JIRA Personal Access Token (Server) or API Token (Cloud)
JIRA_PAT=your_jira_token_here

# JIRA Email (Cloud only) — set this for Jira Cloud (Atlassian Cloud).
# When set, uses Basic Auth (email:token). When empty, uses Bearer PAT (Server).
# JIRA_EMAIL=your.email@company.com
