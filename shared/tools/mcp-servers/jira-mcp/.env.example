# JIRA MCP Server Configuration
#
# JIRA base URL — defaults to https://disneyexperiences.atlassian.net if not set.
JIRA_URL=https://disneyexperiences.atlassian.net

# JIRA Personal Access Token (Server) or API Token (Cloud)
JIRA_PAT=your_jira_token_here

# JIRA Email (Cloud only) — enables Basic Auth + API v3
# JIRA_EMAIL=your.email@company.com

# Custom fields to include in all ticket fetches (comma-separated)
# JIRA_CUSTOM_FIELDS=customfield_10003,customfield_10014,customfield_10020
