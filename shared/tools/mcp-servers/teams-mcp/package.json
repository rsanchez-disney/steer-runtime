{
  "name": "mcp-teams",
  "version": "1.0.0",
  "description": "MCP Server for Microsoft Teams integration via Graph API",
  "type": "module",
  "private": true,
  "main": "dist/index.js",
  "bin": {
    "mcp-teams": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "bundle": "esbuild src/index.ts --bundle --platform=node --format=cjs --outfile=dist/index.cjs --external:playwright",
    "prepare": "npm run build",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "axios": "^1.7.0",
    "playwright": "^1.52.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "esbuild": "^0.20.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.5.0"
  }
}