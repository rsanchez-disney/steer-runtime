{
  "name": "gitlab",
  "description": "GitLab MCP — merge requests, file access, code review, and repository operations",
  "env": {
    "GITLAB_TOKEN": "Personal access token (api scope)",
    "GITLAB_HOST": "GitLab instance hostname (e.g., gitlab.disney.com)"
  },
  "env_required": ["GITLAB_TOKEN"],
  "env_secret": ["GITLAB_TOKEN"],
  "env_defaults": {
    "GITLAB_HOST": "gitlab.disney.com"
  }
}
