# =============================================================================
# GitLab MCP Server — Multi-Instance Configuration
# =============================================================================
# One set of suffixed keys per remote:
# Remote: disney (GitLab Enterprise)
GITLAB_TOKEN_disney=glpat-xxxxxxxxxxxxxxxxxxxx
GITLAB_HOST_disney=gitlab.disney.com

# Remote: public (gitlab.com)
GITLAB_TOKEN_public=glpat-yyyyyyyyyyyyyyyyyyyy
GITLAB_HOST_public=gitlab.com

# Optional: override the API path (defaults to /api/v4 when absent)
# GITLAB_API_PATH_disney=/api/v4
# GITLAB_API_PATH_public=/api/v4

# ── Legacy single-instance (backward compatible) ─────────────────────────────
# For local dev without setup.sh. When GITLAB_HOST is set it takes priority.
#
# GITLAB_URL=https://gitlab.disney.com
# GITLAB_TOKEN=your_gitlab_personal_access_token
