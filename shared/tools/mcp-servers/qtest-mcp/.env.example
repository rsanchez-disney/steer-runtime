# qTest Manager API Configuration
#
# Preferred: set these in ~/.kiro/env.vars (loaded automatically).
# This .env file works as a local override.
#
# Base URL defaults to https://qtest.disney.com if not set.
# Override only if using a different qTest instance:
# QTEST_BASE_URL=https://custom-qtest.example.com

# qTest API Bearer Token (QTEST_TOKEN is also accepted as an alias)
# To obtain a token:
#   1. Log in to your qTest Manager instance
#   2. Navigate to your user profile (gear icon → Profile)
#   3. Under the "API Keys" or "Security" section, generate a new API token
#   4. Copy the bearer token and paste it below
QTEST_BEARER_TOKEN=your_qtest_bearer_token_here

# Default qTest Project ID (optional)
# Set this to avoid passing projectId on every tool call.
# Find your project ID in qTest Manager URL: https://qtest.disney.com/p/<PROJECT_ID>/...
QTEST_PROJECT_ID=
