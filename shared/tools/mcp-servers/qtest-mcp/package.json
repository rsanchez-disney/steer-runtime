{
    "name": "qtest-mcp",
    "version": "0.1.0",
    "description": "qTest MCP server for test management operations",
    "private": true,
    "type": "module",
    "bin": {
        "qtest-mcp": "./build/index.js"
    },
    "files": [
        "build"
    ],
    "scripts": {
        "build": "esbuild src/index.ts --bundle --platform=node --format=cjs --outfile=dist/index.cjs --external:dotenv",
        "test": "vitest --run",
        "lint": "eslint src --ext .ts",
        "lint:fix": "eslint src --ext .ts --fix",
        "format": "prettier --write \"src/**/*.ts\"",
        "format:check": "prettier --check \"src/**/*.ts\""
    },
    "dependencies": {
        "@modelcontextprotocol/sdk": "0.6.0",
        "dotenv": "^16.4.5"
    },
    "devDependencies": {
        "@fast-check/vitest": "^0.1.3",
        "@types/node": "^20.11.24",
        "esbuild": "^0.20.1",
        "eslint": "^8.57.0",
        "fast-check": "^3.15.0",
        "prettier": "^3.2.5",
        "typescript": "^5.3.3",
        "vitest": "^1.3.1"
    }
}
