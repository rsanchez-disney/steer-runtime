{
  "name": "splunk-mcp",
  "version": "0.1.0",
  "description": "Splunk MCP server — search logs, query events, and monitor applications via Splunk REST API",
  "private": true,
  "type": "module",
  "bin": {
    "splunk-mcp": "./build/index.js"
  },
  "files": [
    "build",
    "dist"
  ],
  "scripts": {
    "build": "tsc && node -e \"require('fs').chmodSync('build/index.js', '755')\"",
    "bundle": "esbuild src/index.ts --bundle --platform=node --format=cjs --outfile=dist/index.cjs",
    "prepare": "npm run build",
    "watch": "tsc --watch",
    "inspector": "npx @modelcontextprotocol/inspector build/index.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "0.6.0",
    "dotenv": "^16.4.5",
    "node-fetch": "^3.3.2"
  },
  "devDependencies": {
    "@types/node": "^20.11.24",
    "esbuild": "^0.20.0",
    "typescript": "^5.3.3"
  }
}
