# =============================================================================
# GitHub MCP Server — Multi-Instance Configuration
# =============================================================================
# One set of suffixed keys per remote:
# Remote: disney (GitHub Enterprise)
GITHUB_TOKEN_disney=ghp_xxxxxxxxxxxxxxxxxxxx
GITHUB_HOST_disney=github.disney.com

# Remote: public (github.com)
GITHUB_TOKEN_public=ghp_yyyyyyyyyyyyyyyyyyyy
GITHUB_HOST_public=github.com

# Optional: override the API path (defaults to /api/v3 when absent)
# GITHUB_API_PATH_disney=/api/v3
# GITHUB_API_PATH_public=/api/v3

# ── Legacy single-instance (backward compatible) ─────────────────────────────
# For local dev without setup.sh. When GITHUB_HOST is set it takes priority.
#
# GITHUB_URL=https://github.disney.com
# GITHUB_TOKEN=your_github_personal_access_token
