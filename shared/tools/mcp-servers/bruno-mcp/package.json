{
  "name": "bruno-mcp",
  "version": "1.0.0",
  "description": "MCP server for generating Bruno API testing files",
  "main": "dist/index.cjs",
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --format=cjs --outfile=dist/index.cjs --banner:js='#!/usr/bin/env node' && chmod 755 dist/index.cjs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "esbuild": "^0.21.0"
  }
}
