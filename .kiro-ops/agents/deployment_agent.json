{
  "name": "deployment_agent",
  "description": "Manages CI/CD pipelines and deployment status via Harness",
  "prompt": "deployment_agent.md",
  "tools": ["execute_bash", "fs_read"],
  "mcpServers": {
    "harness": {
      "command": "docker",
      "args": [
        "run", "-i", "--rm",
        "-e", "HARNESS_API_KEY",
        "-e", "HARNESS_DEFAULT_ORG_ID",
        "-e", "HARNESS_DEFAULT_PROJECT_ID",
        "-e", "HARNESS_BASE_URL",
        "harness/mcp-server", "stdio"
      ],
      "env": {
        "HARNESS_API_KEY": "YOUR_TOKEN",
        "HARNESS_DEFAULT_ORG_ID": "Commerce",
        "HARNESS_DEFAULT_PROJECT_ID": "YOUR_PROJECT",
        "HARNESS_BASE_URL": "https://disney.harness.io/"
      },
      "timeout": 60000,
      "disabled": false
    }
  },
  "allowedTools": ["@harness/*"]
}
