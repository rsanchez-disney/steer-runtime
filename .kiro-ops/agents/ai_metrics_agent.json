{
  "name": "ai_metrics_agent",
  "description": "Tracks AI-assisted development metrics and updates Jira tickets",
  "prompt": "ai_metrics_agent.md",
  "tools": [
    "@confluence/*",
    "@github/*",
    "@jira/*",
    "@mywiki/*",
    "execute_bash",
    "fs_read"
  ],
  "mcpServers": {
    "mcp-atlassian": {
      "command": "docker",
      "args": [
        "run",
        "-i",
        "--rm",
        "-e",
        "JIRA_URL",
        "-e",
        "JIRA_PERSONAL_TOKEN",
        "-e",
        "JIRA_SSL_VERIFY",
        "-e",
        "CONFLUENCE_URL",
        "-e",
        "CONFLUENCE_PERSONAL_TOKEN",
        "-e",
        "CONFLUENCE_SSL_VERIFY",
        "ghcr.io/sooperset/mcp-atlassian:latest"
      ],
      "env": {
        "JIRA_URL": "https://myjira.disney.com",
        "JIRA_PERSONAL_TOKEN": "YOUR_TOKEN",
        "JIRA_SSL_VERIFY": "false",
        "CONFLUENCE_URL": "https://confluence.disney.com",
        "CONFLUENCE_PERSONAL_TOKEN": "YOUR_TOKEN",
        "CONFLUENCE_SSL_VERIFY": "false"
      },
      "timeout": 60000,
      "disabled": false
    },
    "jira": {
      "command": "node",
      "args": [
        "$HOME/.kiro/tools/mcp-servers/jira-mcp/dist/index.cjs"
      ],
      "env": {
        "JIRA_PAT": "YOUR_TOKEN"
      }
    },
    "confluence": {
      "command": "node",
      "args": [
        "$HOME/.kiro/tools/mcp-servers/confluence-mcp/dist/index.cjs"
      ],
      "env": {
        "CONFLUENCE_URL": "https://confluence.disney.com",
        "CONFLUENCE_PAT": "YOUR_TOKEN"
      }
    },
    "github": {
      "command": "node",
      "args": [
        "$HOME/.kiro/tools/mcp-servers/github-mcp/dist/index.cjs"
      ],
      "env": {
        "GITHUB_TOKEN_disney": "YOUR_TOKEN",
        "GITHUB_HOST_disney": "github.disney.com",
        "GITHUB_DEFAULT_REMOTE": "disney"
      }
    },
    "mywiki": {
      "command": "node",
      "args": [
        "$HOME/.kiro/tools/mcp-servers/confluence-mcp/dist/index.cjs"
      ],
      "env": {
        "CONFLUENCE_URL": "https://mywiki.disney.com",
        "CONFLUENCE_PAT": "YOUR_TOKEN"
      }
    }
  },
  "allowedTools": [
    "@confluence/*",
    "@github/*",
    "@jira/*",
    "@mcp-atlassian/*",
    "@mywiki/*"
  ],
  "includeMcpJson": true
}
