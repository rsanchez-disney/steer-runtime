{
  "name": "ops_orchestrator_agent",
  "description": "Coordinates ops workflows: AI metrics, deployments, infrastructure checks, code quality",
  "prompt": "ops_orchestrator_agent.md",
  "tools": [
    "@confluence/*",
    "@github/*",
    "@jira/*",
    "@mywiki/*",
    "execute_bash",
    "fs_read",
    "grep",
    "use_subagent"
  ],
  "resources": [
    "file://AGENTS.md",
    "file://.kiro/rules/**/*.md"
  ],
  "welcomeMessage": "\ud83d\udc4b Ops orchestrator ready!\n\nI can help you:\n  \u2022 Track AI productivity metrics for Jira tickets\n  \u2022 Check ECS/AWS infrastructure status\n  \u2022 Review code quality via SonarQube\n  \u2022 Manage CI/CD pipelines via Harness\n\nWhat would you like to do?",
  "mcpServers": {
    "jira": {
      "command": "node",
      "args": [
        "$HOME/.kiro/tools/mcp-servers/jira-mcp/build/index.js"
      ],
      "cwd": "$HOME/.kiro/tools/mcp-servers/jira-mcp",
      "env": {
        "JIRA_PAT": "YOUR_TOKEN"
      }
    },
    "confluence": {
      "command": "node",
      "args": [
        "$HOME/.kiro/tools/mcp-servers/confluence-mcp/build/index.js"
      ],
      "cwd": "$HOME/.kiro/tools/mcp-servers/confluence-mcp",
      "env": {
        "CONFLUENCE_URL": "https://confluence.disney.com",
        "CONFLUENCE_PAT": "YOUR_TOKEN"
      }
    },
    "github": {
      "command": "node",
      "args": [
        "$HOME/.kiro/tools/mcp-servers/github-mcp/build/index.js"
      ],
      "cwd": "$HOME/.kiro/tools/mcp-servers/github-mcp",
      "env": {
        "GITHUB_TOKEN_disney": "YOUR_TOKEN",
        "GITHUB_HOST_disney": "github.disney.com",
        "GITHUB_DEFAULT_REMOTE": "disney"
      }
    },
    "mywiki": {
      "command": "node",
      "args": [
        "$HOME/.kiro/tools/mcp-servers/confluence-mcp/build/index.js"
      ],
      "cwd": "$HOME/.kiro/tools/mcp-servers/confluence-mcp",
      "env": {
        "CONFLUENCE_URL": "https://mywiki.disney.com",
        "CONFLUENCE_PAT": "YOUR_TOKEN"
      }
    }
  },
  "allowedTools": [
    "@confluence/*",
    "@github/*",
    "@jira/*",
    "@mywiki/*"
  ],
  "includeMcpJson": true
}
