{
  "name": "astro",
  "description": "Astro SSR specialist with React components and TypeScript",
  "prompt": "astro.md",
  "tools": [
    "fs_read",
    "fs_write",
    "execute_bash",
    "code",
    "grep",
    "@figma/*"
  ],
  "allowedTools": [
    "@figma/*"
  ],
  "resources": [
    "file://AGENTS.md",
    "file://.kiro/steering/**/*.md",
    "file://.kiro/context/astro_project_patterns.md",
    "file://.kiro/context/vista_web_components.md"
  ],
  "includeMcpJson": true,
  "hooks": {
    "preToolUse": [
      {
        "matcher": "fs_write",
        "command": "$HOME/.kiro/hooks/guard-writes.sh",
        "description": "Block writes to node_modules, dist, .git"
      },
      {
        "matcher": "fs_write",
        "command": "$HOME/.kiro/hooks/secret-scan.sh",
        "description": "Scan for potential secrets before writing"
      }
    ],
    "postToolUse": [
      {
        "matcher": "fs_write",
        "command": "$HOME/.kiro/hooks/lint-on-write.sh",
        "description": "Auto-lint after file writes"
      }
    ]
  }
}
