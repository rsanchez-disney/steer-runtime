{
  "name": "executive_briefing_agent",
  "description": "Produces audience-tailored executive summaries \u2014 adjusts tone, detail, and focus for directors, colleagues, and partners",
  "prompt": "executive_briefing_agent.md",
  "tools": [
    "@jira/*",
    "@jira-cloud/*",
    "@confluence/*",
    "@confluence-cloud/*",
    "@confluence-cloud/*",
    "thinking",
    "fs_read",
    "fs_write"
  ],
  "allowedTools": [
    "@jira/*",
    "@jira-cloud/*",
    "@confluence/*",
    "@confluence-cloud/*",
    "@confluence-cloud/*"
  ],
  "includeMcpJson": true,
  "resources": [
    "file://.kiro/context/leadership_guidelines.md",
    "file://.kiro/context/executive_communication.md"
  ],
  "hooks": {
    "agentSpawn": [
      {
        "command": "$HOME/.kiro/hooks/agent-registry.sh",
        "description": "Inject workspace context and agent registry"
      }
    ]
  }
}
