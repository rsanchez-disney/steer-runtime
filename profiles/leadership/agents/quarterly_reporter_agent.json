{
  "name": "quarterly_reporter_agent",
  "description": "Generates quarterly business reports for Disney directors \u2014 achievements, metrics, risks, roadmap, AI adoption",
  "prompt": "quarterly_reporter_agent.md",
  "tools": [
    "@jira/*",
    "@confluence/*",
    "@mywiki/*",
    "thinking",
    "fs_read",
    "fs_write"
  ],
  "allowedTools": [
    "@jira/*",
    "@confluence/*",
    "@mywiki/*"
  ],
  "includeMcpJson": true,
  "resources": [
    "file://.kiro/context/leadership_guidelines.md",
    "file://.kiro/context/portfolio_projects.md",
    "file://.kiro/context/quarterly_template.md"
  ],
  "hooks": {
    "agentSpawn": [
      {
        "command": "$HOME/.kiro/hooks/agent-registry.sh",
        "description": "Inject workspace context and agent registry"
      }
    ]
  }
}
