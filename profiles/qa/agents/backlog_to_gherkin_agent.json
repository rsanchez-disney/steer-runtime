{
  "name": "backlog_to_gherkin_agent",
  "description": "Fetches XRay TCs, classifies candidates, scans repo, generates .feature files with gated approval",
  "tools": [
    "@jira/*",
    "@jira-cloud/*",
    "@xray/*",
    "jira_get_myself",
    "jira_search_issues",
    "xray_get_test_steps",
    "xray_get_test_case_full",
    "jira_get_issue",
    "fs_read",
    "fs_write",
    "grep",
    "execute_bash",
    "@confluence/*",
    "@confluence-cloud/*"
  ],
  "allowedTools": [
    "@jira/*",
    "@jira-cloud/*",
    "@xray/*",
    "jira_get_myself",
    "jira_search_issues",
    "xray_get_test_steps",
    "xray_get_test_case_full",
    "jira_get_issue",
    "fs_read",
    "fs_write",
    "grep",
    "execute_bash",
    "@confluence/*",
    "@confluence-cloud/*"
  ],
  "resources": [
    "file://profiles/qa/prompts/backlog_to_gherkin_agent.md",
    "file://profiles/qa/context/xray_fetching_instructions.md",
    "file://profiles/qa/context/xray_classification_logic.md",
    "file://profiles/qa/context/readiness_assessment.md",
    "file://profiles/qa/context/repo_scanning_instructions.md",
    "file://profiles/qa/context/feature_generation_guidelines.md"
  ],
  "hooks": {
    "preToolUse": [
      {
        "matcher": "fs_write",
        "command": "$HOME/.kiro/hooks/guard-feature-only.sh",
        "description": "Only allow writing .feature files"
      },
      {
        "matcher": "fs_write",
        "command": "$HOME/.kiro/hooks/secret-scan.sh",
        "description": "Scan for potential secrets before writing"
      }
    ]
  },
  "includeMcpJson": true,
  "welcomeMessage": "🤖 Backlog to Gherkin (v3)\n\nStart with:\n  @get_jira_backlog — I will ask for repo path and XRay path step by step\n\nAfter classification:\n  @get_automation_ready_candidates — Scan repo, show readiness table\n  @write_scenario — Generate .feature files for 🟢 candidates"
}
