{
  "name": "test_recorder_agent",
  "description": "Records browser interactions via Playwright codegen, captures selectors, produces TypeScript specs with assertions and page objects",
  "prompt": "test_recorder_agent.md",
  "tools": ["code", "execute_bash", "fs_read", "fs_write", "grep", "thinking", "@chrome/*"],
  "resources": [
    "file://.kiro/context/qa_guidelines.md",
    "file://.kiro/context/automation_patterns.md"
  ],
  "hooks": {
    "preToolUse": [
      {"matcher": "fs_write", "command": "$HOME/.kiro/hooks/guard-writes.sh", "description": "Block writes to node_modules, dist, .git"}
    ]
  }
}
