{
  "name": "api_test_executor_agent",
  "description": "Executes XRay Gherkin test cases against service APIs via Bruno MCP",
  "prompt": "api_test_executor_agent.md",
  "tools": ["fs_read", "execute_bash", "thinking", "grep"],
  "resources": ["file://.kiro/context/qa_guidelines.md"],
  "allowedTools": ["@bruno-mcp/*", "@jira/*"],
  "includeMcpJson": true,
  "welcomeMessage": "🔌 API Test Executor ready!...",
  "hooks": {
    "preToolUse": [
      {
        "matcher": "execute_bash",
        "command": "$HOME/.kiro/hooks/secret-scan.sh",
        "description": "Scan for secrets before writing"
      }
    ]
  }
}
