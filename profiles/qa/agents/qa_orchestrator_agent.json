{
  "name": "qa_orchestrator_agent",
  "description": "Orchestrates QA tasks and coordinates specialized testing agents for test planning, automation, defect analysis, API testing, performance testing, and coverage analysis",
  "prompt": "qa_orchestrator_agent.md",
  "tools": [
    "@confluence/*",
    "@mywiki/*",
    "@github/*",
    "@gitlab/*",
    "@jira/*",
    "code",
    "execute_bash",
    "fs_read",
    "fs_write",
    "grep",
    "subagent",
    "thinking",
    "todo_list",
    "@bruno/*",
    "@qtest/*",
    "@yax/*"
  ],
  "allowedTools": [
    "@confluence/*",
    "@mywiki/*",
    "@github/*",
    "@gitlab/*",
    "@jira/*",
    "@bruno/*",
    "@compass/*",
    "@qtest/*",
    "@yax/*"
  ],
  "resources": [
    "file://.kiro/context/qa_guidelines.md",
    "file://.kiro/context/test_templates.md",
    "file://.kiro/context/qtest_guidelines.md",
    "file://.kiro/context/mcp_priority.md",
    "file://.kiro/context/orchestrator_rules.md",
    "file://.kiro/context/sdlc-workflow.md",
    "file://.kiro/context/_dynamic/delegation-map.md"
  ],
  "includeMcpJson": true,
  "welcomeMessage": "👋 QA orchestrator ready!\n\nI can help you:\n  • Create test plans from Jira stories\n  • Generate automated test scripts\n  • Analyze defects and find root causes\n  • Run API and performance tests\n\nTry: \"Create test plan for <JIRA-ID>\"",
  "hooks": {
    "agentSpawn": [
      {
        "command": "$HOME/.kiro/hooks/git-context.sh",
        "description": "Inject git branch and status"
      },
      {
        "command": "$HOME/.kiro/hooks/agent-registry.sh",
        "description": "Inject available agents registry for dynamic delegation"
      },
      {
        "command": "$HOME/.kiro/hooks/delegation-map.sh",
        "description": "Generate delegation map for routing decisions"
      }
    ],
    "preToolUse": [
      {
        "matcher": "execute_bash",
        "command": "$HOME/.kiro/hooks/branch-guard.sh",
        "description": "Block direct commits to main/master"
      }
    ]
  }
}
