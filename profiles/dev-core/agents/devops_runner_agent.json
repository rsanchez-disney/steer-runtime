{
  "name": "devops_runner_agent",
  "description": "Executes builds, tests, git operations, and local dev commands. The orchestrator delegates all build/test/git tasks here.",
  "prompt": "devops_runner_agent.md",
  "tools": [
    "execute_bash",
    "fs_read",
    "fs_write",
    "grep",
    "code",
    "thinking",
    "@bruno/*"
  ],
  "includeMcpJson": false,
  "resources": [
    "file://.kiro/context/api_testing_with_bruno.md"
  ],
  "hooks": {
    "preToolUse": [
      {
        "matcher": "execute_bash",
        "command": "$HOME/.kiro/hooks/block-suspicious.sh",
        "description": "Block commands that trigger EDR alerts (browser DBs, credential stores)"
      },
      {
        "matcher": "execute_bash",
        "command": "$HOME/.kiro/hooks/branch-guard.sh",
        "description": "Block direct commits to main/master"
      }
    ]
  }
}
