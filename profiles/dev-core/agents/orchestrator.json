{
  "name": "orchestrator",
  "description": "SDLC orchestrator with automatic multi-agent delegation for Jira story implementation",
  "prompt": "orchestrator.md",
  "tools": [
    "subagent",
    "execute_bash",
    "grep",
    "code",
    "fs_read",
    "thinking",
    "todo_list",
    "@yax/*",
    "@bruno/*"
  ],
  "resources": [
    "file://AGENTS.md",
    "file://.kiro/context/golden_rules.md",
    "file://.kiro/context/project_mappings.md",
    "file://.kiro/context/orchestrator_rules.md",
    "file://.kiro/context/sdlc-workflow.md",
    "file://.kiro/steering/**/*.md",
    "file://.kiro/context/mcp_priority.md",
    "file://.kiro/context/domain_context.md",
    "file://.kiro/context/team_context.md",
    "file://.kiro/context/api_testing_with_bruno.md"
  ],
  "welcomeMessage": "\ud83d\udc4b Ready to orchestrate your development workflow!\n\nI can help you:\n  \u2022 Implement Jira stories: \"Help me implement <JIRA_URL>\"\n  \u2022 Coordinate multi-repo features across backend, webapi, ui\n  \u2022 Run full SDLC: story \u2192 plan \u2192 implement \u2192 review \u2192 PR",
  "hooks": {
    "agentSpawn": [
      {
        "command": "$HOME/.kiro/hooks/git-context.sh",
        "description": "Inject git branch and status"
      },
      {
        "command": "$HOME/.kiro/hooks/agent-registry.sh",
        "description": "Inject available agents registry for dynamic delegation"
      },
      {
        "command": "$HOME/.kiro/hooks/delegation-map.sh",
        "description": "Generate delegation map for routing decisions"
      }
    ],
    "preToolUse": [
      {
        "matcher": "fs_write",
        "command": "$HOME/.kiro/hooks/guard-writes.sh",
        "description": "Block writes to node_modules, dist, .git"
      },
      {
        "matcher": "execute_bash",
        "command": "$HOME/.kiro/hooks/branch-guard.sh",
        "description": "Block direct commits to main/master"
      }
    ],
    "postToolUse": [
      {
        "matcher": "execute_bash",
        "command": "$HOME/.kiro/hooks/warn-destructive.sh",
        "description": "Warn on destructive commands"
      }
    ],
    "stop": [
      {
        "command": "$HOME/.kiro/hooks/session-summary.sh",
        "description": "Log session telemetry to JSONL"
      },
      {
        "command": "$HOME/.kiro/hooks/session-to-memory.sh",
        "description": "Update active-context.md with session summary"
      }
    ]
  },
  "includeMcpJson": true,
  "allowedTools": [
    "@yax/*"
  ]
}
