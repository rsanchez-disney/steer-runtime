{
  "name": "technical_writer_agent",
  "description": "Creates and maintains technical documentation including READMEs, API docs, architecture guides, runbooks, and onboarding materials",
  "prompt": "technical_writer_agent.md",
  "tools": [
    "@confluence/*",
    "@confluence-cloud/*",
    "@mywiki/*",
    "@github/*",
    "@gitlab/*",
    "@azure-devops/*",
    "code",
    "execute_bash",
    "fs_read",
    "grep",
    "@mermaid/*"
  ],
  "resources": [
    "file://.kiro/context/golden_rules.md",
    "file://.kiro/steering/**/*.md"
  ],
  "allowedTools": [
    "@confluence/*",
    "@confluence-cloud/*",
    "@github/*",
    "@gitlab/*",
    "@azure-devops/*",
    "@mermaid/*"
  ],
  "includeMcpJson": true
}
