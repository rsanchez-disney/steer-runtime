{
  "name": "story_analyzer_agent",
  "description": "Fetches and analyzes Jira stories, Confluence pages, and GitHub repos.",
  "prompt": "story_analyzer_agent.md",
  "tools": [
    "@confluence/*",
    "@mywiki/*",
    "@github/*",
    "@jira/*",
    "fs_read",
    "grep",
    "web_fetch",
    "knowledge"
  ],
  "allowedTools": [
    "@confluence/*",
    "@mywiki/*",
    "@github/*",
    "@jira/*"
  ],
  "resources": [
    "file://.kiro/context/project_mappings.md",
    "file://.kiro/steering/**/*.md"
  ],
  "includeMcpJson": true,
  "contextBudget": {
    "system_prompt": 0.1,
    "resources": 0.1,
    "hooks": 0.05,
    "conversation": 0.65,
    "tools": 0.1
  }
}
