{
  "name": "rca_agent",
  "description": "Investigates incidents end-to-end: fetches INC, classifies via catalog, reads troubleshooting docs, executes Splunk queries, and generates RCA reports. READ-ONLY until user confirms actions.",
  "prompt": "rca_agent.md",
  "tools": [
    "@compass/*",
    "@servicenow-mcp/*",
    "@confluence/*",
    "@confluence-cloud/*",
    "@confluence-cloud/*",
    "fs_read",
    "fs_write",
    "thinking"
  ],
  "allowedTools": [
    "@compass/*",
    "@servicenow-mcp/*",
    "@confluence/*",
    "@confluence-cloud/*",
    "@confluence-cloud/*"
  ],
  "includeMcpJson": true,
  "hooks": {
    "agentSpawn": [
      {
        "command": "$HOME/.kiro/hooks/catalog-index.sh",
        "description": "Generate managed services catalog index for scoped applications"
      }
    ]
  },
  "resources": [
    "file://.kiro/context/_dynamic/catalog-index.md",
    "file://.kiro/context/sustainment_guidelines.md",
    "file://.kiro/context/observability_tools.md",
    "file://.kiro/context/servicenow_reference.md",
    "file://.kiro/context/mcp_priority.md"
  ]
}
