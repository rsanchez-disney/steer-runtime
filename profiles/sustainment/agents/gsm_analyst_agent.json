{
  "name": "gsm_analyst_agent",
  "description": "GSM analysis — impact summaries, SLA tracking, incident trends, and service health reporting",
  "prompt": "gsm_analyst_agent.md",
  "tools": [
    "@jira/*",
    "@confluence/*",
    "@mywiki/*",
    "@compass/*",
    "fs_read",
    "fs_write",
    "thinking"
  ],
  "allowedTools": [
    "@jira/*",
    "@confluence/*",
    "@mywiki/*",
    "@compass/*"
  ],
  "includeMcpJson": true,
  "hooks": {
    "agentSpawn": [
      {
        "command": "$HOME/.kiro/hooks/catalog-index.sh",
        "description": "Generate managed services catalog index for scoped applications"
      }
    ]
  },
  "resources": [
    "file://.kiro/context/_dynamic/catalog-index.md",
    "file://.kiro/context/sustainment_guidelines.md",
    "file://.kiro/context/servicenow_reference.md",
    "file://.kiro/context/mcp_priority.md"
  ]
}
