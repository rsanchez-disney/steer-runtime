{
  "name": "incident_triage_agent",
  "description": "Classifies and triages incidents from ServiceNow, Jira, and alerts \u2014 determines severity, impact, and routing",
  "prompt": "incident_triage_agent.md",
  "tools": [
    "@jira/*",
    "@compass/*",
    "fs_read",
    "thinking",
    "@teams/*"
  ],
  "allowedTools": [
    "@jira/*",
    "@compass/*"
  ],
  "includeMcpJson": true,
  "hooks": {
    "agentSpawn": [
      {
        "command": "$HOME/.kiro/hooks/catalog-index.sh",
        "description": "Generate managed services catalog index for scoped applications"
      }
    ]
  },
  "resources": [
    "file://.kiro/context/_dynamic/catalog-index.md",
    "file://.kiro/context/sustainment_guidelines.md",
    "file://.kiro/context/servicenow_reference.md",
    "file://.kiro/context/mcp_priority.md"
  ]
}
