# MCP configuration with tokens
mcp-config.json

# NOTE: ~/.kiro/config.json and ~/.cursor/mcp.json live outside the repo.
# Git cannot track or ignore files outside the working tree.
# To ignore them globally, add to your personal global gitignore:
#   git config --global core.excludesFile ~/.gitignore
# Then add these patterns to ~/.gitignore:
#   .kiro/config.json
#   .cursor/mcp.json

# Backup files
*.backup
*.bak
*.bak2
*.bak3
*.bak4
*.bak5

# macOS
.DS_Store

# Editor
.vscode/
.idea/

# Logs
*.log

# Distribution packages
# dist/ — project level, but MCP dist/ is committed via negation below
*.zip

# MCP servers (if you want to keep them private)
# mcp-servers/

# MCP servers internal files
node_modules/
.kiro/tools/mcp-servers/*/.git/
.kiro/tools/mcp-servers/*/.env
.kiro/tools/mcp-servers/*/build/
!.kiro/tools/mcp-servers/*/dist/
.kiro/tools/mcp-servers/*/*.log
.kiro/tools/mcp-servers/*/package-lock.json
tests/runs/
.kiro/settings/
steer-runtime-*.tar.gz
._*
VERSION

# Kiro IDE hooks (workspace-level, not committed)
.kiro/hooks/

# Cursor IDE (workspace-level)
.cursor/mcp.json
.cursor/.koda-meta.json
.cursor/rules/
.cursor/agents/
.cursor/skills/

site/

# Generated reports (output of certify.py / eval runs)
evals/results/CERTIFICATION.md
tests/orchestration/Q*-Quarterly-Report.md

