{
  "name": "standup_agent",
  "description": "Generates daily standup summaries from Jira activity, flags blockers and stale items",
  "prompt": "standup_agent.md",
  "tools": [
    "@jira/*",
    "execute_bash",
    "fs_read"
  ],
  "resources": [],
  "mcpServers": {
    "jira": {
      "command": "node",
      "args": [
        "$HOME/.kiro/tools/mcp-servers/jira-mcp/dist/index.cjs"
      ],
      "env": {
        "JIRA_PAT": "YOUR_TOKEN"
      }
    }
  },
  "allowedTools": [
    "@jira/*"
  ],
  "includeMcpJson": true
}
