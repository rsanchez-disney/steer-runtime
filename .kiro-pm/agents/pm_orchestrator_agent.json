{
  "name": "pm_orchestrator_agent",
  "description": "Coordinates PM/Scrum Master workflows and delegates to specialized agents for sprint management, standups, retros, risk tracking, and delivery reporting",
  "prompt": "pm_orchestrator_agent.md",
  "tools": [
    "@jira/*",
    "@confluence/*",
    "@mywiki/*",
    "@github/*",
    "code",
    "execute_bash",
    "fs_read",
    "grep"
  ],
  "resources": [
    "file://.kiro/context/golden_rules.md",
    "file://.kiro/steering/**/*.md"
  ],
  "mcpServers": {
    "jira": {
      "command": "node",
      "args": [
        "$HOME/.kiro/tools/mcp-servers/jira-mcp/dist/index.cjs"
      ],
      "env": {
        "JIRA_PAT": "YOUR_TOKEN"
      }
    },
    "confluence": {
      "command": "node",
      "args": [
        "$HOME/.kiro/tools/mcp-servers/confluence-mcp/dist/index.cjs"
      ],
      "env": {
        "CONFLUENCE_URL": "https://confluence.disney.com",
        "CONFLUENCE_PAT": "YOUR_TOKEN"
      }
    },
    "github": {
      "command": "node",
      "args": [
        "$HOME/.kiro/tools/mcp-servers/github-mcp/dist/index.cjs"
      ],
      "env": {
        "GITHUB_TOKEN_disney": "YOUR_TOKEN",
        "GITHUB_HOST_disney": "github.disney.com",
        "GITHUB_DEFAULT_REMOTE": "disney"
      }
    },
    "mywiki": {
      "command": "node",
      "args": [
        "$HOME/.kiro/tools/mcp-servers/confluence-mcp/dist/index.cjs"
      ],
      "env": {
        "CONFLUENCE_URL": "https://mywiki.disney.com",
        "CONFLUENCE_PAT": "YOUR_TOKEN"
      }
    }
  },
  "allowedTools": [
    "@jira/*",
    "@confluence/*",
    "@mywiki/*",
    "@github/*"
  ],
  "includeMcpJson": true
}
